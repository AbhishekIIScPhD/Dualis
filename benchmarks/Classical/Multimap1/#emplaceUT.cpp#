int main(int argc, char* argv[]) {
    if (argc < 2) {
        std::cerr << "Error: Please provide a file path for logging." << std::endl;
        return 1;
    }
    std::string filePath = argv[1];
    std::ofstream ceFile(filePath, std::ios::out);
    if (!ceFile) {
        std::cerr << "Error: Unable to open log file." << std::endl;
        return 1;
    }

    ceFile << "(emplace k v countko len countko1 len1)\n";

    rc::check("testing std::multimap emplace", [&ceFile](std::multimap<int, int> map) {
        int k = *rc::gen::inRange(MIN, MAX);
        int v = *rc::gen::inRange(MIN, MAX);
	int len = map.size();
	int k_one = 1;
	int countko = map.count(k_one);
        map.emplace(k, v);
	int countko1 = map.count(k_one);
	int len1 = map.size();
	bool expr = (((k <= 0) or ((((k > 1) and (countko1 <= 0)) or ((((k > 1) and ((countko1 - countko) <= 0)) or ((countko1 - countko) > 0)) and (countko1 > 0))) and (k > 0))) and ((countko1 - countko) <= 1) and ((len1 - len) > 0));
        if (!expr) {
            ceFile << "k=" << k
		   << ", v=" << v
                   << ", countko=" << countko
		   << ", len=" << len
                   << ", countko1=" << countko1
		   << ", len1=" << len1
                   << std::endl;
        }
        RC_ASSERT(expr);
    });

    ceFile.close();
    std::cout << "Tests completed. Log written to " << filePath << std::endl;
    return 0;
}
