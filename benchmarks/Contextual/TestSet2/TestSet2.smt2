(declare-var pisEmpty Int)
(declare-var pisEmpty1 Int)
(declare-var nisEmpty Int)
(declare-var nisEmpty1 Int)
(declare-var pmin Int)
(declare-var pmin1 Int)
(declare-var nmax Int)
(declare-var nmax1 Int)
(declare-var psum Int)
(declare-var psum1 Int)
(declare-var nsum Int)
(declare-var nsum1 Int)
(declare-var N Int)
(declare-var i Int)
(declare-var v1 Int)
(declare-var sum1 Int)
(declare-var sum2 Int)

(declare-rel inv (Int Int Int Int Int Int Int))
(declare-rel insert1 (Int Int Int Int Int))
(declare-rel insert2 (Int Int Int Int Int))
(declare-rel computeSum1 (Int Int Int))
(declare-rel computeSum2 (Int Int Int))
(declare-rel fail ())

(define-fun is_valid ((x Int)) Bool (or (= x 1) (= x 0)))
(define-fun MAX () Int 127)
(define-fun MIN () Int -128)

(rule (=> (and (= i 0) (= psum 0) (= pisEmpty 1) (= pmin MAX) (= nsum 0) (= nisEmpty 1) (= nmax MIN)) (inv i psum pisEmpty pmin nsum nisEmpty nmax)))
(rule (=> (and (inv i psum pisEmpty pmin nsum nisEmpty nmax) (< i N) (>= v1 0) (insert1 v1 psum psum1 pmin pmin1) (= i1 (+ i 1))) (inv i1 psum1 0 pmin1 nsum nisEmpty nmax)))
(rule (=> (and (inv i psum pisEmpty pmin nsum nisEmpty nmax) (< i N) (< v1 0) (insert2 v1 nsum nsum1 nmax nmax1)) (inv (+ i 1) psum pisEmpty pmin nsum1 0 nmax1)))
(rule (=> (and (inv i psum pisEmpty pmin nsum nisEmpty nmax) (>= i N) (computeSum1 pisEmpty psum sum1) (computeSum2 nisEmpty nsum sum2) (not (and (or (= nisEmpty 1) (< sum2 0)) (or (= pisEmpty 1) (>= sum1 0))))) fail))

(query fail :print-certificate true)