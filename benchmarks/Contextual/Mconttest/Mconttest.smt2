(declare-var x Int)
(declare-var x1 Int)
(declare-var flag Int)
(declare-var N Int)
(declare-var i Int)
(declare-var v Int)
(declare-rel foo1 (Int Int Int))
(declare-rel foo2 (Int Int Int))
(declare-rel inv (Int))
(declare-rel fail ())

(rule (=> (and (= x 0))(inv x)))
(rule (=> (and (inv x) (>= i 0) (< i N) (and (=> (not (= v 0)) (and (= flag 0) (foo1 flag x x1))) (=> (= v 0) (and (= flag 1) (foo2 flag x x1))))) (inv x1)))
(rule (=> (and (inv x) (= x 10000)) fail))

(query fail :print-certificate true)